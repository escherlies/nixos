# =============================================================================
# Restic exclude patterns — developer workstation home directory
#
# Used by the restic module (modules/restic.nix) via --exclude-file.
# The backup also uses --exclude-caches to honor CACHEDIR.TAG files.
#
# Strategy: back up everything, exclude only reproducible garbage.
# When in doubt, keep it — disk is cheap, lost data is not.
# =============================================================================


# =============================================================================
# 1. PACKAGE MANAGER CACHES AND ARTIFACTS
# =============================================================================

# Node.js — fully reproducible from lockfiles
**/node_modules

# Bun global install cache
.bun/install/cache

# npm/yarn/pnpm caches
.npm/_cacache
.cache/yarn
.cache/pnpm
.local/share/pnpm/store

# Nix / direnv — symlinks into /nix/store
