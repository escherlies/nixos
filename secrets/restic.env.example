# Restic backup credentials — encrypt this file with agenix:
#
#   cd secrets/
#   cp restic.env.example restic.env
#   # Fill in the values
#   agenix -e restic.env.age < restic.env
#   rm restic.env
#
# For Backblaze B2:
#   1. Create a B2 bucket (private, no lifecycle rules)
#   2. Create an application key scoped to that bucket
#   3. Repository URL format: s3:s3.<region>.backblazeb2.com/<bucket-name>
#
# For AWS S3:
#   Repository URL format: s3:s3.<region>.amazonaws.com/<bucket-name>

RESTIC_REPOSITORY=s3:s3.us-west-004.backblazeb2.com/your-bucket-name
RESTIC_PASSWORD=generate-a-strong-password-and-store-it-safely
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-application-key
